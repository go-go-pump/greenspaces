# Deployment Platform — Environment Variables
# Copy to .env.deploy and customize for your project.

DEPLOY_PROJECT_ID=my-project
DEPLOY_ENV=production
DEPLOY_HISTORY_DB=./data/deploy-history.sqlite
DEPLOY_DASHBOARD_ROUTE=/admin/deployments
DEPLOY_VERSION_SCHEME=semver
DEPLOY_ACTOR=whoami
DEPLOY_ACTOR_TYPE=human
# DEPLOY_HISTORY_JSON=./deploys/history.jsonl  # Flat file fallback (uncomment if no SQLite)
# DEPLOY_METRIC_ENDPOINT=http://localhost:9090  # metric-beacon URL (optional)
