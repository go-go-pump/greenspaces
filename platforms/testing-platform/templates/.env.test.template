# Testing Platform — Environment Configuration
# Copy to .env.test and customize for your project

# App
TEST_BASE_URL=http://localhost:3000
TEST_DB_PATH=./data/test.db

# Deterministic mode
TEST_MODE=true
TEST_SEED=42
TEST_EPOCH=2026-01-01T00:00:00Z

# Playwright
PLAYWRIGHT_HEADED=false
PLAYWRIGHT_TIMEOUT=30000

# Coverage (NYC/c8)
COVERAGE_DIR=./coverage
