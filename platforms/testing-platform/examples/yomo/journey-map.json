{
  "journeyId": "yomo-campaign-lifecycle",
  "name": "YOMO Campaign Lifecycle",
  "description": "End-to-end campaign flow: create → generate → render → publish → analytics",
  "domain": "yomo",
  "version": "1.0.0",
  "steps": [
    {
      "step": 1,
      "name": "Create Campaign",
      "description": "Founder creates a new video campaign with topic and keyword targeting",
      "preconditions": [],
      "actions": [
        "Navigate to /campaigns/new",
        "Enter campaign name and topic",
        "Select keyword targets",
        "Click 'Create Campaign'"
      ],
      "postconditions": [
        "Campaign record exists with status 'created'",
        "Campaign has associated keyword targets"
      ],
      "artifacts": ["campaign_record", "keyword_targets"],
      "seedScript": "seeds/seed-step-1.mjs",
      "testSpec": "yomo-campaign.spec.ts"
    },
    {
      "step": 2,
      "name": "Generate Assets",
      "description": "vidgen-pipeline generates script, visuals, and voiceover for the campaign",
      "preconditions": ["Campaign exists with status 'created'"],
      "actions": [
        "Navigate to /campaigns/:id",
        "Click 'Generate Assets'",
        "Wait for generation to complete"
      ],
      "postconditions": [
        "Script record exists",
        "Visual assets generated (slides/images)",
        "Voiceover audio generated",
        "Campaign status is 'assets-ready'"
      ],
      "artifacts": ["script_record", "visual_assets", "voiceover_audio"],
      "seedScript": "seeds/seed-step-2.mjs",
      "testSpec": "yomo-campaign.spec.ts"
    },
    {
      "step": 3,
      "name": "Render Video",
      "description": "Assets assembled into final MP4 video with thumbnail",
      "preconditions": ["Campaign status is 'assets-ready'"],
      "actions": [
        "Navigate to /campaigns/:id",
        "Click 'Render Video'",
        "Wait for render to complete",
        "Preview video in player"
      ],
      "postconditions": [
        "MP4 file exists in output directory",
        "Thumbnail generated",
        "Campaign status is 'rendered'",
        "Video player shows preview"
      ],
      "artifacts": ["mp4_file", "thumbnail", "render_metadata"],
      "seedScript": "seeds/seed-step-3.mjs",
      "testSpec": "yomo-campaign.spec.ts"
    },
    {
      "step": 4,
      "name": "Publish to YouTube",
      "description": "Video uploaded to YouTube with metadata (mocked in test mode)",
      "preconditions": ["Campaign status is 'rendered'", "MP4 file exists"],
      "actions": [
        "Navigate to /campaigns/:id",
        "Click 'Publish'",
        "Confirm publish dialog",
        "Wait for upload confirmation"
      ],
      "postconditions": [
        "YouTube video ID recorded (mocked)",
        "Campaign status is 'published'",
        "Publish timestamp recorded"
      ],
      "artifacts": ["youtube_video_id", "publish_record"],
      "seedScript": "seeds/seed-step-4.mjs",
      "testSpec": "yomo-campaign.spec.ts"
    },
    {
      "step": 5,
      "name": "View Analytics",
      "description": "Founder views campaign performance metrics (mocked data)",
      "preconditions": ["Campaign status is 'published'"],
      "actions": [
        "Navigate to /campaigns/:id/analytics",
        "View views count",
        "View watch time",
        "View engagement metrics"
      ],
      "postconditions": [
        "Analytics dashboard displays metrics",
        "Views count is visible",
        "Watch time is visible",
        "CTR is visible"
      ],
      "artifacts": ["analytics_snapshot"],
      "seedScript": "seeds/seed-step-5.mjs",
      "testSpec": "yomo-campaign.spec.ts"
    }
  ]
}
